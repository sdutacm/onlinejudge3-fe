{
  "name": "onlinejudge3-fe",
  "version": "3.7.4",
  "description": "",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": "24.x",
    "pnpm": "11.2.2"
  },
  "scripts": {
    "dev": "gulp dev",
    "dev:competition-side": "cross-env COMPETITION_SIDE=1 gulp dev",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider BROWSER=none umi dev",
    "dup-less": "gulp dup-less",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider umi build",
    "build:ssr": "cross-env NODE_OPTIONS=--openssl-legacy-provider OJ3_SSR=1 umi build",
    "build:ssr:competition-side": "cross-env NODE_OPTIONS=--openssl-legacy-provider OJ3_SSR=1 COMPETITION_SIDE=1 OJ3_BUILD4=release_competition_side umi build",
    "serve:ssr": "node server/index.js",
    "start:ssr": "pm2 start ecosystem.config.js",
    "reload:ssr": "pm2 reload ecosystem.config.js",
    "stop:ssr": "pm2 stop ecosystem.config.js",
    "test:ssr": "node --test tests/ssr/*.test.js",
    "build:cdn": "pnpm run build && node tasks/upload-cdn.js",
    "build:competition-side": "cross-env NODE_OPTIONS=--openssl-legacy-provider COMPETITION_SIDE=1 OJ3_BUILD4=release_competition_side umi build",
    "build:competition-side:cdn": "pnpm run build:competition-side && cross-env COMPETITION_SIDE=1 node tasks/upload-cdn.js onlinejudge3_cs",
    "build-analyze": "cross-env NODE_OPTIONS=--openssl-legacy-provider ANALYZE=1 umi build",
    "check:built-assets": "node tasks/check-built-output-assets.js",
    "check:dva-models": "node tasks/check-dva-model-registration.js",
    "e2e:built": "playwright test -c playwright.built.config.js tests/e2e/built-output.spec.ts",
    "e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "e2e:smoke:headed": "playwright test tests/e2e/smoke.spec.ts --headed",
    "line-count": "cloc src/ --exclude-dir=.umi,.umi-production --fullpath --not-match-f='/(styles/dark_antd|styles/dark_antd_duplicated4auto|assets|configs/codes)/'",
    "pull-submodule": "git submodule foreach git pull origin master",
    "report:built-assets": "node tasks/report-built-assets.js",
    "report:pnpm-peer-baseline": "node tasks/report-pnpm-peer-baseline.js",
    "report:typecheck-baseline": "node tasks/report-typecheck-baseline.js",
    "serve:built": "node tasks/serve-built-output.js",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false --skipLibCheck",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdutacm/onlinejudge3-fe.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sdutacm/onlinejudge3-fe/issues"
  },
  "homepage": "https://github.com/sdutacm/onlinejudge3-fe#readme",
  "dependencies": {
    "@umijs/renderer-react": "3.5.43",
    "animate.css": "3.7.2",
    "antd": "3.11.6",
    "axios": "0.18.1",
    "bowser": "2.11.0",
    "braft-editor": "2.3.9",
    "braft-utils": "3.0.12",
    "classnames": "2.5.1",
    "cross-env": "6.0.3",
    "csshake": "1.5.3",
    "dva": "2.6.0-beta.23",
    "file-saver": "2.0.5",
    "filesize": "6.4.0",
    "highcharts": "7.2.2",
    "highcharts-react-official": "2.2.2",
    "howler": "2.2.4",
    "image-promise": "5.0.1",
    "immutable": "3.7.6",
    "js-base64": "3.7.2",
    "js-cookie": "2.2.1",
    "jscookie": "1.1.0",
    "katex": "0.16.9",
    "koa": "3.2.1",
    "koa-mount": "4.2.0",
    "koa-static": "5.0.0",
    "lodash": "4.18.1",
    "lodash-es": "4.17.21",
    "lodash.throttle": "4.1.1",
    "markdown-it": "13.0.2",
    "math-precision": "1.0.5",
    "md5": "2.3.0",
    "memoize-one": "5.2.1",
    "mitt": "3.0.1",
    "moment": "2.30.1",
    "nprogress": "0.2.0",
    "pm2": "7.0.1",
    "promise-queue": "2.2.5",
    "react": "17.0.2",
    "react-autolatex": "2.0.1",
    "react-calendar-heatmap": "1.8.1",
    "react-copy-to-clipboard": "5.0.4",
    "react-document-title": "2.0.3",
    "react-dom": "17.0.2",
    "react-ga": "2.7.0",
    "react-markdown": "3.6.0",
    "react-player": "2.13.0",
