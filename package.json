    "batch": "0.6.1",
    "cloc": "2.9.0",
    "cos-nodejs-sdk-v5": "2.12.5",
    "eslint": "6.8.0",
    "eslint-config-alloy": "3.10.0",
    "eslint-plugin-react": "7.28.0",
    "fs-extra": "8.1.0",
    "gulp": "4.0.2",
    "gulp-rename": "2.0.0",
    "gulp-run-command": "0.0.10",
    "gulp-watch": "5.0.1",
    "npm-run-all": "4.1.5",
    "prettier": "1.19.1",
    "roadhog-api-doc": "1.1.2",
