    "react-toastify": "8.2.0",
    "react-tooltip": "3.11.6",
    "reflect-metadata": "0.2.2",
    "short-number": "1.0.7",
    "socket.io-client": "2.4.0",
    "url-assembler": "1.2.10",
    "xlsx": "0.15.6",
    "xss": "1.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
