{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "importHelpers": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@@/*": ["src/.umi/*"],
      "umi/link": ["src/compat/umiLink.ts"],
      "umi/router": ["src/compat/umiRouter.ts"],
      "umi/withRouter": ["src/compat/umiWithRouter.ts"]
    },
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true
  }
}
